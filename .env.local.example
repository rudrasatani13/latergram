# Template for local development on a developer machine.
# Provider: Supabase Auth
# Copy this file to .env.local and fill in your real local development keys.
# .env.local is gitignored and will not be committed.

VITE_SUPABASE_URL=your_local_supabase_url
VITE_SUPABASE_ANON_KEY=your_local_supabase_anon_key
