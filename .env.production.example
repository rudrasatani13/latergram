# Template for the production/live environment.
# Provider: Supabase Auth
# Do not commit real production keys!
# Production values should be configured in the hosting platform environment settings (e.g. Vercel, Netlify).

VITE_SUPABASE_URL=your_production_supabase_url
VITE_SUPABASE_ANON_KEY=your_production_supabase_anon_key

# Privacy-respecting analytics are disabled by default.
# Supported provider: plausible
# These are public frontend values, not secrets. Configure only after policy review.
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_PROVIDER=
VITE_PLAUSIBLE_DOMAIN=
VITE_PLAUSIBLE_SCRIPT_SRC=
