# Template for the development/staging environment.
# Provider: Supabase Auth
# Copy this file to .env.development if you need local staging testing, or configure these in your hosting provider's development settings.

VITE_SUPABASE_URL=your_development_supabase_url
VITE_SUPABASE_ANON_KEY=your_development_supabase_anon_key

# Privacy-respecting analytics are disabled by default.
# Supported provider: plausible
# These are public frontend values, not secrets. Leave disabled unless configured.
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_PROVIDER=
VITE_PLAUSIBLE_DOMAIN=
VITE_PLAUSIBLE_SCRIPT_SRC=
