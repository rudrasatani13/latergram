# General reference for all required auth environment variables.
# Provider: Supabase Auth
# Do not put real keys here. Do not commit real keys to the repository.

# Supabase URL and Anon Key are required for auth to work.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Privacy-respecting analytics are disabled by default.
# Supported provider: plausible
# These are public frontend values, not secrets. Leave disabled unless configured.
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_PROVIDER=
VITE_PLAUSIBLE_DOMAIN=
VITE_PLAUSIBLE_SCRIPT_SRC=
